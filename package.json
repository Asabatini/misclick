{
  "name": "misclick-guild-manager",
  "version": "1.0.0",
  "description": "WoW guild management site with roster tracking, raid calendar, and boss assignments",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon --watch server --exec ts-node server/index.ts",
    "client:dev": "cd client && npm run dev",
    "build": "cd client && npm install && npm run build && cd .. && npm run build:server",
    "build:server": "tsc -p server/tsconfig.json",
    "build:client": "cd client && npm run build",
    "start": "node dist/index.js",
    "setup": "npm install && cd client && npm install"
  },
  "keywords": ["wow", "guild", "management", "raid", "roster"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "better-sqlite3": "^9.2.2",
    "axios": "^1.6.5",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.6",
    "@types/better-sqlite3": "^7.6.8",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "nodemon": "^3.0.2",
    "concurrently": "^8.2.2"
  }
}
