{
  "name": "misclick-guild-manager",
  "version": "1.0.0",
  "description": "WoW guild management site with roster tracking, raid calendar, and boss assignments",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon --watch server --exec ts-node server/index.ts",
    "client:dev": "cd client && npm run dev",
    "build": "cd client && npm install && npm run build",
    "build:server": "tsc -p server/tsconfig.json",
    "build:client": "cd client && npm run build",
    "start": "ts-node server/index.ts",
    "setup": "npm install && cd client && npm install"
  },
  "keywords": [
    "wow",
    "guild",
    "management",
    "raid",
    "roster"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^9.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "winston": "^3.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
