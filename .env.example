# Server Configuration
PORT=3001
NODE_ENV=production

# JWT Authentication (REQUIRED)
JWT_SECRET=your_super_secure_random_secret_key_here

# Client URL for CORS (REQUIRED for production)
CLIENT_URL=https://your-app.onrender.com

# API Base URL for scheduler (REQUIRED for production)
API_BASE_URL=https://your-app.onrender.com

# Blizzard API Configuration
BLIZZARD_CLIENT_ID=your_blizzard_client_id_here
BLIZZARD_CLIENT_SECRET=your_blizzard_client_secret_here
BLIZZARD_REGION=us

# WoW Guild Configuration
WOW_REALM=your-realm-slug
WOW_GUILD_NAME=Your Guild Name

# Database
DATABASE_PATH=./data/guild.db

# Logging
LOG_LEVEL=info
