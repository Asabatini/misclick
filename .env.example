# Server Configuration
PORT=3001
NODE_ENV=development

# Blizzard API Configuration
BLIZZARD_CLIENT_ID=your_blizzard_client_id_here
BLIZZARD_CLIENT_SECRET=your_blizzard_client_secret_here
BLIZZARD_REGION=us

# WoW Guild Configuration
WOW_REALM=your-realm-slug
WOW_GUILD_NAME=Your Guild Name

# Database
DATABASE_PATH=./data/guild.db

# Logging
LOG_LEVEL=info
